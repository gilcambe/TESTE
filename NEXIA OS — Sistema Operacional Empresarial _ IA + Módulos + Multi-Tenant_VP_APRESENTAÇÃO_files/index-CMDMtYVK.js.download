— documentação completa",auth:!1}],PN=[{title:"CORTEX IA — Integração Groq Real",lang:"TypeScript",color:"#8B5CF6",icon:"ri-robot-line",desc:"Chamada real à API Groq Llama 3 usada em todos os chats CORTEX do projeto",code:`// src/pages/nexia-admin/components/CortexChat.tsx
const apiKey = (import.meta as any).env?.VITE_GROQ_API_KEY;

const response = await fetch(
  'https://api.groq.com/openai/v1/chat/completions',
  {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Authorization: \`Bearer \${apiKey}\`,
    },
    body: JSON.stringify({
      model: 'llama3-8b-8192',
      messages: [
        { role: 'system', content: 'Você é o CORTEX...' },
        { role: 'user', content: userMessage },
      ],
      max_tokens: 800,
    }),
  }
);
const data = await response.json();
const reply = data.choices[0].message.content;`},{title:"NexiaSplash — Animação de Abertura",lang:"TypeScript",color:"#00E5FF",icon:"ri-play-circle-line",desc:"Componente que aparece antes de cada página com logo NEXIA animado",code:`// src/components/feature/NexiaSplash.tsx
export default function NexiaSplash({ onDone }: { onDone: () => void }) {
  useEffect(() => {
    const shown = sessionStorage.getItem('nexia-splash');
    if (shown) { onDone(); return; }
    const t = setTimeout(() => {
      sessionStorage.setItem('nexia-splash', '1');
      onDone();
    }, 2500);
    return () => clearTimeout(t);
  }, [onDone]);

  return (
    <div style={{ position:'fixed', inset:0, background:'#07090E',
      display:'flex', alignItems:'center', justifyContent:'center',
      zIndex:9999 }}>
      {/* Logo NEXIA hexagonal animado */}
      <div style={{ animation: 'spin 3s linear infinite' }}>N</div>
    </div>
  );
}`},{title:"Auth System — Login Multi-Produto",lang:"TypeScript",color:"#10B981",icon:"ri-lock-line",desc:"Sistema de login único que funciona para todos os produtos NEXIA",code:`// src/lib/auth.ts
const CREDENTIALS = {
  'admin@nexia.com':           { pass: 'Gil0102@',     role: 'nexia-admin',    path: '/nexia/admin' },
  'henrique@cesbrasil.tech':   { pass: 'Henrique01@',  role: 'ces-admin',      path: '/ces/admin' },
  'henrique@viajantepro.com':  { pass: 'Henrique01@',  role: 'vp-admin',       path: '/viajante-pro/admin' },
  'admin@bezsan.com':          { pass: 'Bezsan2026@',  role: 'bezsan-admin',   path: '/bezsan/admin' },
  'admin@journeypartners.com': { pass: 'JP2027@',      role: 'jp-admin',       path: '/jp/admin' },
  'admin@splashlazer.com.br':  { pass: 'splash2027',   role: 'splash-admin',   path: '/splash/admin' },
};

export function login(email: string, pass: string) {
  const user = CREDENTIALS[email];
  if (user && user.pass === pass) return user;
  return null;
}`},{title:"Router Config — Todas as 23 Rotas",lang:"TypeScript",color:"#F59E0B",icon:"ri-route-line",desc:"Configuração completa de rotas do React Router v6 do projeto",code:`// src/router/config.tsx
import type { RouteObject } from "react-router-dom";
// ... imports de todas as páginas ...

const routes: RouteObject[] = [
  { path: "/",                          element: <Home /> },
  { path: "/login",                     element: <LoginPage /> },
  { path: "/ces",                       element: <CesLandingPage /> },
  { path: "/ces/admin",                 element: <CesAdminPage /> },
  { path: "/ces/app",                   element: <CesAppPage /> },
  { path: "/ces/presentation",          element: <CesPresentationPage /> },
  { path: "/viajante-pro",              element: <ViajanteProLanding /> },
  { path: "/viajante-pro/admin",        element: <ViajanteAdminPage /> },
  { path: "/viajante-pro/passageiro",   element: <VPPassengerApp /> },
  { path: "/viajante-pro/guia",         element: <VPGuideApp /> },
  { path: "/jp",                        element: <JPLandingPage /> },
  { path: "/jp/admin",                  element: <JPAdminPage /> },
  { path: "/nexia/admin",               element: <NexiaMasterAdmin /> },
  { path: "/nexia/presentation",        element: <NexiaCinematicPage /> },
  { path: "/nexia/status",              element: <NexiaStatusPage /> },
  { path: "/bezsan",                    element: <BezsanPage /> },
  { path: "/bezsan/admin",              element: <BezsanAdminPage /> },
  { path: "/splash/admin",              element: <SplashAdminPage /> },
  { path: "/project-docs",              element: <ProjectDocsPage /> },
  { path: "*",                          element: <NotFound /> },
];
export default routes;`},{title:"NexiaWatermark — Marca em todos os sites",lang:"TypeScript",color:"#EC4899",icon:"ri-watermark-line",desc:"Componente de watermark NEXIA usado em todos os produtos clientes",code:`// src/components/feature/NexiaWatermark.tsx
interface Props {
  variant?: 'footer' | 'corner';
}

export default function NexiaWatermark({ variant = 'footer' }: Props) {
  if (variant === 'corner') {
    return (
      <div style={{
        position: 'fixed', bottom: '16px', right: '16px',
        opacity: 0.3, fontSize: '10px', color: '#fff',
        display: 'flex', alignItems: 'center', gap: '4px',
        zIndex: 1000,
      }}>
        <span>POWERED BY</span>
        <strong style={{ color: '#00E5FF' }}>NEXIA OS</strong>
      </div>
    );
  }
  return (
    <div style={{ textAlign: 'center', padding: '12px', opacity: 0.25 }}>
      POWERED BY <strong>NEXIA OS</strong>
    </div>
  );
}`},{title:"App.tsx — Estrutura Principal",lang:"TypeScript",color:"#F97316",icon:"ri-code-box-line",desc:"Componente raiz com BrowserRouter, NexiaSplash e AppRoutes",code:`// src/App.tsx
import { useState, useCallback } from 'react';
import { BrowserRouter } from 'react-router-dom';
import { AppRoutes } from './router';
import NexiaSplash from './components/feature/NexiaSplash';

declare const __BASE_PATH__: string;

export default function App() {
  const [splashDone, setSplashDone] = useState(false);
  const handleDone = useCallback(() => setSplashDone(true), []);

  return (
    <>
      {!splashDone && <NexiaSplash onDone={handleDone} />}
      <BrowserRouter basename={__BASE_PATH__}>
        <AppRoutes />
      </BrowserRouter>
    </>
  );
}`}],MN=[{name:"React 19",desc:"Framework UI",color:"#00E5FF",icon:"ri-reactjs-line"},{name:"TypeScript",desc:"Tipagem estática",color:"#0EA5E9",icon:"ri-code-s-slash-line"},{name:"Vite",desc:"Build & Dev Server",color:"#F59E0B",icon:"ri-flashlight-line"},{name:"TailwindCSS",desc:"Estilização",color:"#14B8A6",icon:"ri-palette-line"},{name:"React Router v6",desc:"Navegação SPA",color:"#EC4899",icon:"ri-route-line"},{name:"Groq API",desc:"IA Llama 3 grátis",color:"#8B5CF6",icon:"ri-robot-line"},{name:"Remix Icons",desc:"2.000+ ícones",color:"#F97316",icon:"ri-remixicon-line"},{name:"FontAwesome",desc:"Ícones extras",color:"#10B981",icon:"ri-font-size"}],LN=[{n:"1",title:"Export via Readdy.ai",desc:'Na barra superior do Readdy.ai, clique no botão "Export" ou ícone de download. Isso baixa o projeto inteiro como ZIP.',icon:"ri-download-cloud-2-line",color:"#00E5FF"},{n:"2",title:"Deploy na Vercel",desc:"Arraste o ZIP exportado para a Vercel (vercel.com). Em 2 minutos seu projeto está online com URL pública.",icon:"ri-rocket-line",color:"#10B981"},{n:"3",title:"Deploy na Netlify",desc:"Alternativa gratuita. Arraste a pasta para netlify.com/drop. Zero configuração necessária.",icon:"ri-global-line",color:"#F59E0B"},{n:"4",title:"Variável Groq (IA real)",desc:"Para ativar a IA real: adicione VITE_GROQ_API_KEY no .env. Chave gratuita em console.groq.com",icon:"ri-key-line",color:"#8B5CF6"}];function VN(){const[r,e]=I.useState("src/pages"),[t,a]=I.useState(null),[o,c]=I.useState(""),[u,p]=I.useState("structure"),h=(y,E)=>{navigator.clipboard.writeText(y).catch(()=>{}),a(E),setTimeout(()=>a(null),2e3)},f=Q5.flatMap(y=>y.files),b=o?f.filter(y=>y.path.toLowerCase().includes(o.toLowerCase())||y.desc.toLowerCase().includes(o.toLowerCase())):null,v=f.length;return n.jsxs("div",{style:{minHeight:"100vh",background:"#07090E",color:"#F8FAFC",fontFamily:'"Inter", sans-serif'},children:[n.jsx("div",{style:{background:"rgba(0,0,0,0.4)",borderBottom:"1px solid rgba(0,229,255,0.15)",paddin